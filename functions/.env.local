# Loaded ONLY by the Firebase emulator (never by deploy) and takes precedence
# over .env there: the test suites serve their synthetic feed on this port,
# and the mail provider is a local stub the tests control.
DATA_BASE_URL=http://127.0.0.1:8126
MAIL_API_URL=http://127.0.0.1:8127
MAIL_SENDER=test@league.local
# BREVO_API_KEY lives in functions/.secret.local (the emulator's secrets file)
